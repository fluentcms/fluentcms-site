---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="FluentCMS | AI-Powered Headless CMS Built with ASP.NET Core and Blazor"
  description="FluentCMS is an AI-powered, open-source headless CMS built with ASP.NET Core and Blazor. Features AI content generation, site builder, headless architecture, and modern UI/UX. MIT licensed, 500+ GitHub stars."
  keywords="FluentCMS, headless CMS, Blazor CMS, ASP.NET Core CMS, AI CMS, open source CMS, .NET CMS, content management system, headless content management, AI content generation, Blazor headless CMS, .NET headless CMS, CMS for .NET, dotnet cms, blazor web development, AI content writing, headless architecture"
>
  <header>
    <nav class="bg-white/90 backdrop-blur-md border-b border-gray-200 dark:bg-gray-950/90 dark:border-gray-800 sticky top-0 z-50">
      <div class="max-w-screen-xl mx-auto px-3 sm:px-4">
        <div class="flex flex-wrap items-center justify-between h-14 sm:h-16">
          <a href="/" class="flex items-center">
            <img src="/logo.svg" class="h-7 sm:h-9 mr-2 dark:hidden" alt="FluentCMS Logo">
            <img src="/logo-dark.svg" class="h-7 sm:h-9 mr-2 hidden dark:block" alt="FluentCMS Logo">
          </a>
          <div class="flex items-center md:order-2 gap-2">
            <a href="https://github.com/fluentcms/FluentCMS" target="_blank" rel="noopener noreferrer" class="text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-xs sm:text-sm px-3 sm:px-4 py-1.5 sm:py-2 text-center inline-flex items-center gap-1 sm:gap-2 dark:focus:ring-blue-800">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
              <span class="hidden xs:inline">Star</span>
            </a>
            <button id="theme-toggle" type="button" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 rounded-lg text-sm p-2" aria-label="Toggle dark mode">
              <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
              </svg>
              <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"></path>
              </svg>
            </button>
            <button data-collapse-toggle="navbar-cta" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-800 dark:focus:ring-gray-600" aria-controls="navbar-cta" aria-expanded="false">
              <span class="sr-only">Open main menu</span>
              <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
              </svg>
            </button>
          </div>
          <div class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1" id="navbar-cta">
            <ul class="flex flex-col font-medium p-4 md:p-0 mt-4 border border-gray-100 rounded-lg bg-gray-50 md:flex-row md:space-x-6 md:mt-0 md:border-0 dark:bg-gray-800 md:dark:bg-transparent dark:border-gray-700">
              <li>
                <a href="#about-section" class="block py-2 pl-3 pr-4 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-800 dark:hover:text-white md:dark:hover:bg-transparent dark:border-gray-700">About</a>
              </li>
              <li>
                <a href="#features-section" class="block py-2 pl-3 pr-4 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-800 dark:hover:text-white md:dark:hover:bg-transparent dark:border-gray-700">Features</a>
              </li>
              <li>
                <a href="#get-started" class="block py-2 pl-3 pr-4 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-800 dark:hover:text-white md:dark:hover:bg-transparent dark:border-gray-700">Get Started</a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-b from-gray-50 to-white dark:from-gray-950 dark:to-gray-900">
      <div class="absolute inset-0 -z-10">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-blue-100 via-transparent to-transparent dark:from-blue-950/30"></div>
      </div>
      <div class="max-w-screen-xl px-3 sm:px-4 py-12 sm:py-16 lg:py-24 mx-auto">
        <div class="text-center">
          <a href="https://github.com/fluentcms/FluentCMS" class="inline-flex items-center justify-between px-3 sm:px-4 py-2 mb-6 sm:mb-8 text-xs sm:text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-full shadow-sm hover:bg-gray-50 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-700 dark:hover:bg-gray-700" role="alert">
            <span class="flex items-center justify-center w-5 h-5 sm:w-6 sm:h-6 mr-2 text-xs text-white bg-blue-600 rounded-full">✦</span>
            <span class="mr-2 sm:mr-3">See our latest progress</span>
            <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
          <h1 class="mb-6 sm:mb-8 text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 dark:text-white">
            Welcome to <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-blue-400">FluentCMS</span>
            <span class="block mt-2 sm:mt-4 text-lg sm:text-xl lg:text-2xl font-medium text-gray-500 dark:text-gray-400">
              AI Driven ASP.NET Core Blazor Content Management System (CMS)
            </span>
          </h1>
          <p class="mb-8 sm:mb-10 text-sm sm:text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto px-4 sm:px-0">
            Building and managing content has never been easier. Experience the power of AI with FluentCMS - the modern, open-source headless CMS built with Blazor.
          </p>
          <div class="flex flex-col space-y-3 sm:flex-row sm:justify-center sm:space-y-0 sm:space-x-4 px-4 sm:px-0">
            <a href="https://github.com/fluentcms/FluentCMS" target="_blank" rel="noopener noreferrer" class="inline-flex justify-center items-center py-3 px-5 sm:px-6 text-sm sm:text-base font-medium text-center text-white rounded-lg bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:ring-4 focus:ring-blue-300 dark:focus:ring-blue-800 shadow-lg transition-all duration-300">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
              Get Started
            </a>
            <a href="#features-section" class="inline-flex justify-center items-center py-3 px-5 sm:px-6 text-sm sm:text-base font-medium text-center text-gray-900 rounded-lg border border-gray-300 hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 dark:text-white dark:border-gray-700 dark:hover:bg-gray-700 dark:focus:ring-gray-800 transition-all duration-300">
              Explore Features
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="bg-white dark:bg-gray-950 py-8 sm:py-12">
      <div class="max-w-screen-xl px-3 sm:px-4 mx-auto">
        <div class="grid grid-cols-2 gap-4 sm:gap-8 md:grid-cols-4">
          <div class="text-center">
            <div class="text-2xl sm:text-3xl font-bold text-blue-600 dark:text-blue-400">537+</div>
            <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">GitHub Stars</div>
          </div>
          <div class="text-center">
            <div class="text-2xl sm:text-3xl font-bold text-blue-600 dark:text-blue-400">106+</div>
            <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">Forks</div>
          </div>
          <div class="text-center">
            <div class="text-2xl sm:text-3xl font-bold text-blue-600 dark:text-blue-400">50+</div>
            <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">Contributors</div>
          </div>
          <div class="text-center">
            <div class="text-2xl sm:text-3xl font-bold text-blue-600 dark:text-blue-400">MIT</div>
            <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">License</div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about-section" class="bg-white dark:bg-gray-950 py-12 sm:py-16 lg:py-24">
      <div class="max-w-screen-xl px-3 sm:px-4 mx-auto lg:px-6">
        <div class="grid gap-8 md:grid-cols-2">
          <div class="space-y-4 sm:space-y-6">
            <div class="p-4 sm:p-6 bg-gray-50 dark:bg-gray-800 rounded-2xl">
              <div class="w-12 sm:w-14 h-12 sm:h-14 mb-3 sm:mb-4 rounded-xl bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
                <svg class="w-6 sm:w-8 h-6 sm:h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h3 class="text-lg sm:text-xl font-bold dark:text-white mb-2 sm:mb-3">Open-Source Headless CMS</h3>
              <p class="text-sm sm:text-base text-gray-500 dark:text-gray-400">
                A modern, open-source headless CMS built with ASP.NET Core and Blazor. Provides flexibility and scalability for content delivery to any platform.
              </p>
            </div>
            <div class="p-4 sm:p-6 bg-gray-50 dark:bg-gray-800 rounded-2xl">
              <div class="w-12 sm:w-14 h-12 sm:h-14 mb-3 sm:mb-4 rounded-xl bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
                <svg class="w-6 sm:w-8 h-6 sm:h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <h3 class="text-lg sm:text-xl font-bold dark:text-white mb-2 sm:mb-3">AI-Driven Content Creation</h3>
              <p class="text-sm sm:text-base text-gray-500 dark:text-gray-400">
                Leverage AI to improve content efficiency with intelligent tools that analyze trends and generate personalized, high-quality content.
              </p>
            </div>
          </div>
          <div class="flex flex-col justify-center">
            <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-4 sm:mb-6">
              Build Faster with AI-Powered Content Management
            </h2>
            <p class="text-sm sm:text-lg text-gray-500 dark:text-gray-400 mb-6 sm:mb-8">
              Effortlessly create, manage, and deliver content with our AI-driven platform built on modern .NET technology. FluentCMS combines the power of ASP.NET Core with artificial intelligence.
            </p>
            <div class="grid grid-cols-2 gap-3 sm:gap-4">
              <div class="p-3 sm:p-4 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
                <div class="text-xl sm:text-2xl font-bold text-blue-600 dark:text-blue-400 mb-1">AI</div>
                <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">Writing Assistant</div>
              </div>
              <div class="p-3 sm:p-4 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
                <div class="text-xl sm:text-2xl font-bold text-blue-600 dark:text-blue-400 mb-1">Blazing</div>
                <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">Fast Performance</div>
              </div>
              <div class="p-3 sm:p-4 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
                <div class="text-xl sm:text-2xl font-bold text-blue-600 dark:text-blue-400 mb-1">Extensible</div>
                <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">Plugins & Themes</div>
              </div>
              <div class="p-3 sm:p-4 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
                <div class="text-xl sm:text-2xl font-bold text-blue-600 dark:text-blue-400 mb-1">Modern</div>
                <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">UI/UX Design</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Modern CMS Section -->
    <section class="bg-gray-50 dark:bg-gray-900 py-12 sm:py-16 lg:py-24">
      <div class="max-w-screen-xl px-3 sm:px-4 mx-auto lg:px-6">
        <div class="grid gap-8 lg:grid-cols-2 items-center">
          <div>
            <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-4 sm:mb-6">
              Why Choose a Headless CMS for .NET Development?
            </h2>
            <p class="text-sm sm:text-lg text-gray-500 dark:text-gray-400 mb-4 sm:mb-6">
              Traditional CMS platforms limit customization, integration, and personalization. FluentCMS fills this gap with a modern, open-source headless CMS built with ASP.NET Core and Blazor. Deliver content to websites, mobile apps, IoT devices, and more from a single source.
            </p>
          </div>
          <div>
            <p class="text-sm sm:text-lg text-gray-500 dark:text-gray-400">
              With <strong>AI-powered content creation</strong> and management, plus a <strong>site builder</strong> for easy page creation, FluentCMS gives developers and marketers the tools they need to create personalized, engaging experiences. The headless architecture allows you to use any frontend framework while benefiting from the power of .NET and Blazor.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features-section" class="bg-white dark:bg-gray-950 py-12 sm:py-16 lg:py-24">
      <div class="max-w-screen-xl px-3 sm:px-4 mx-auto lg:px-6">
        <div class="text-center mb-10 sm:mb-16">
          <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-3 sm:mb-4">
            Powerful Features for Modern Content Management
          </h2>
          <p class="text-sm sm:text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
            Everything you need to build, manage, and deliver content at scale with AI-powered tools
          </p>
        </div>
        <div class="grid gap-4 sm:gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          <!-- Feature 1 -->
          <div class="p-4 sm:p-6 bg-gray-50 dark:bg-gray-800 rounded-2xl hover:shadow-xl transition-shadow duration-300">
            <div class="w-10 sm:w-12 h-10 sm:h-12 mb-3 sm:mb-4 rounded-xl bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
              <svg class="w-5 sm:w-6 h-5 sm:h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-base sm:text-lg font-bold dark:text-white mb-2">AI-Powered Content</h3>
            <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">
              Utilize NLP and ML to generate high-quality content.
            </p>
          </div>
          <!-- Feature 2 -->
          <div class="p-4 sm:p-6 bg-gray-50 dark:bg-gray-800 rounded-2xl hover:shadow-xl transition-shadow duration-300">
            <div class="w-10 sm:w-12 h-10 sm:h-12 mb-3 sm:mb-4 rounded-xl bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
              <svg class="w-5 sm:w-6 h-5 sm:h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
              </svg>
            </div>
            <h3 class="text-base sm:text-lg font-bold dark:text-white mb-2">Headless Architecture</h3>
            <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">
              Build scalable applications with separated front and back ends.
            </p>
          </div>
          <!-- Feature 3 -->
          <div class="p-4 sm:p-6 bg-gray-50 dark:bg-gray-800 rounded-2xl hover:shadow-xl transition-shadow duration-300">
            <div class="w-10 sm:w-12 h-10 sm:h-12 mb-3 sm:mb-4 rounded-xl bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
              <svg class="w-5 sm:w-6 h-5 sm:h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
              </svg>
            </div>
            <h3 class="text-base sm:text-lg font-bold dark:text-white mb-2">Sitebuilder Interface</h3>
            <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">
              Create user-friendly interfaces without coding.
            </p>
          </div>
          <!-- Feature 4 -->
          <div class="p-4 sm:p-6 bg-gray-50 dark:bg-gray-800 rounded-2xl hover:shadow-xl transition-shadow duration-300">
            <div class="w-10 sm:w-12 h-10 sm:h-12 mb-3 sm:mb-4 rounded-xl bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
              <svg class="w-5 sm:w-6 h-5 sm:h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
